POSTGRES_HOST=postgres
PHX_BIND=0.0.0.0
YOUTUBE_PROXY_HOST=host.docker.internal
YOUTUBE_PROXY_PORT=10808
YOUTUBE_DISCOVERY_ADAPTER=yt_dlp
YOUTUBE_ARCHIVE_LIMIT=7500
YOUTUBE_TRANSCRIPT_LANGS=ru-orig,ru
YT_DLP_JS_RUNTIME=node
YT_DLP_COOKIES_PATH=/data/youtube/cookies.txt
YT_DLP_PATH=yt-dlp

# AI provider for VPS/background analysis.
# Use "openai" for OpenAI or any chat-completions compatible API.
AI_PROVIDER=openai
AI_ENDPOINT=https://api.openai.com/v1/chat/completions
AI_MODEL=gpt-4o-mini
AI_TEMPERATURE=0.2
AI_TIMEOUT_MS=120000
AI_INPUT_USD_PER_1M=0.15
AI_OUTPUT_USD_PER_1M=0.60
OPENAI_API_KEY=
